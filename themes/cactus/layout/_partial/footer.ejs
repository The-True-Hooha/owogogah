<footer id="footer">
  <div class="footer-left">
    &copy; <%= (theme.copyright && theme.copyright.start_year) ? theme.copyright.start_year : new Date().getFullYear() %>–<%= new Date().getFullYear() %>
    <%= config.author || config.title %> &middot;
    <a href="https://www.gogahlabstechnologies.com" target="_blank" rel="noopener">gogah labs</a>
    &middot; <a href="/atom.xml" title="RSS feed">rss</a>
  </div>
  <div class="footer-right">
    <nav>
      <ul>
        <% for (var i in theme.nav) { %><!--
       --><li><a href="<%- url_for(theme.nav[i]) %>"><%= __('nav.'+i).replace("nav.", "") %></a></li><!--
     --><% } %>
      </ul>
    </nav>
  </div>
</footer>

// ================================================================
// owogogah — easter egg styles: terminal, bios, cursor, progress
// ================================================================

// ── READING PROGRESS BAR ─────────────────────────────────────────

#read-progress
  display: none
  position: fixed
  top: 0
  left: 0
  right: 0
  height: 2px
  z-index: 9999
  background: transparent

#read-bar
  height: 100%
  width: 0%
  background: $color-accent-1
  transition: width 0.1s linear
  box-shadow: 0 0 6px rgba(43, 188, 138, 0.6)

// ── CURSOR NODE ──────────────────────────────────────────────────

#cursor-node
  display: none
  position: fixed
  top: 0
  left: 0
  width: 6px
  height: 6px
  border-radius: 50%
  background: $color-accent-1
  pointer-events: none
  z-index: 9998
  opacity: 0.5
  box-shadow: 0 0 8px rgba(43, 188, 138, 0.6)
  transition: opacity 0.3s ease

  body:hover &
    opacity: 0.7

// ── HIDDEN TERMINAL ──────────────────────────────────────────────

#lab-terminal
  display: none
  position: fixed
  inset: 0
  background: rgba(0, 0, 0, 0.75)
  z-index: 9000
  align-items: center
  justify-content: center
  backdrop-filter: blur(4px)

  &.lt-open
    display: flex

.lt-inner
  width: min(680px, 92vw)
  background: #0e1012
  border: 1px solid rgba(43, 188, 138, 0.3)
  border-radius: 6px
  overflow: hidden
  font-family: $font-family-mono
  box-shadow: 0 0 40px rgba(43, 188, 138, 0.12), 0 20px 60px rgba(0,0,0,0.6)

.lt-titlebar
  display: flex
  align-items: center
  gap: 6px
  padding: 10px 14px
  background: #161819
  border-bottom: 1px solid rgba(43, 188, 138, 0.12)

.lt-dot
  width: 10px
  height: 10px
  border-radius: 50%

.lt-dot-red    { background: #ff5f57 }
.lt-dot-yellow { background: #febc2e }
.lt-dot-green  { background: #28c840 }

.lt-title
  font-size: 11px
  color: #555
  letter-spacing: 0.08em
  margin-left: 6px

.lt-body
  min-height: 220px
  max-height: 340px
  overflow-y: auto
  padding: 12px 16px
  font-size: 12px
  line-height: 1.7
  color: #c9cacc
  scrollbar-width: thin
  scrollbar-color: rgba(43,188,138,0.3) transparent

.lt-welcome
  color: #555
  font-size: 11px
  margin-bottom: 6px

.lt-line
  min-height: 1.2em
  white-space: pre-wrap
  word-break: break-all

.lt-input-row
  display: flex
  align-items: center
  padding: 10px 16px
  border-top: 1px solid rgba(43, 188, 138, 0.12)
  background: #0e1012

.lt-prompt
  color: $color-accent-1
  font-size: 12px
  white-space: nowrap
  flex-shrink: 0

#lt-input
  flex: 1
  background: transparent
  border: none
  outline: none
  color: #c9cacc
  font-family: $font-family-mono
  font-size: 12px
  caret-color: $color-accent-1

// terminal color helpers
.t-green { color: $color-accent-1 }
.t-dim   { color: #555 }
.t-red   { color: #ff5f57 }

// ── BIOS BOOT OVERLAY ────────────────────────────────────────────

#bios-overlay
  display: none
  position: fixed
  inset: 0
  background: #000
  z-index: 9999
  align-items: flex-start
  justify-content: flex-start
  padding: 3rem

  &.bios-active
    display: flex

#bios-out
  font-family: $font-family-mono
  font-size: 13px
  line-height: 1.65
  color: #c9cacc
  white-space: pre
  max-width: 680px

  @media (max-width: 480px)
    font-size: 10px
    padding: 0

// ── TOKEN STREAM ─────────────────────────────────────────────────

@keyframes token-scroll
  from
    transform: translateX(0)
  to
    transform: translateX(-50%)

.token-stream
  overflow: hidden
  width: 100%
  margin-bottom: 2.5rem
  mask-image: linear-gradient(90deg, transparent 0%, black 8%, black 92%, transparent 100%)
  -webkit-mask-image: linear-gradient(90deg, transparent 0%, black 8%, black 92%, transparent 100%)

.token-track
  display: flex
  gap: 0
  width: max-content
  animation: token-scroll 28s linear infinite

  span
    font-size: 9px
    letter-spacing: 0.1em
    color: $color-meta
    opacity: 0.35
    padding: 0 1rem
    white-space: nowrap
    border-right: 1px solid rgba(144,141,141,0.12)

    &:nth-child(3n)
      color: $color-accent-1
      opacity: 0.25

    &:nth-child(5n)
      opacity: 0.2

// ── KEYBOARD SHORTCUTS OVERLAY ───────────────────────────────────

#kb-help
  display: none
  position: fixed
  inset: 0
  z-index: 10000
  background: rgba(29, 31, 33, 0.85)
  backdrop-filter: blur(4px)
  align-items: center
  justify-content: center

  &.kb-open
    display: flex

#kb-help-inner
  background: #1d1f21
  border: 1px solid rgba(43, 188, 138, 0.25)
  border-radius: 4px
  padding: 1.5rem 2rem
  min-width: 280px
  font-family: $font-family-mono

.kb-title
  font-size: 10px
  letter-spacing: 0.2em
  text-transform: uppercase
  color: $color-accent-1
  opacity: 0.7
  margin-bottom: 1.2rem

.kb-table
  width: 100%
  border-collapse: collapse

  td
    font-size: 12px
    padding: 4px 0
    color: $color-meta
    vertical-align: middle

  td:first-child
    padding-right: 1.5rem
    white-space: nowrap

  kbd
    display: inline-block
    padding: 1px 5px
    font-size: 10px
    font-family: $font-family-mono
    color: $color-text
    background: rgba(255,255,255,0.06)
    border: 1px solid rgba(255,255,255,0.12)
    border-radius: 2px
    margin-right: 2px

.kb-close
  margin-top: 1.2rem
  font-size: 10px
  color: $color-meta
  opacity: 0.35
  text-align: center

// ── SHIMMER (live experiment card) ───────────────────────────────

@keyframes exp-shimmer
  0%
    background-position: -200% center
  100%
    background-position: 200% center

.exp-card--live
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(43, 188, 138, 0.06) 40%,
    rgba(43, 188, 138, 0.10) 50%,
    rgba(43, 188, 138, 0.06) 60%,
    transparent 100%
  )
  background-size: 200% 100%
  animation: exp-shimmer 3s ease-in-out infinite

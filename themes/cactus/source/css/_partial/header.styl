// ── HEADER ───────────────────────────────────────────────────────────

#header
  margin: 0 auto 2.5rem
  width: 100%
  display: flex
  align-items: center
  justify-content: space-between

  h1, .h1
    margin: 0
    color: $color-text
    letter-spacing: -0.01em
    font-weight: 700
    font-style: normal
    font-size: 1.1rem
    line-height: 1

    antialias()

  a
    background: none
    background-image: none
    color: inherit
    text-decoration: none

    &:hover
      background: none
      background-image: none

  #title
    h1
      font-family: $font-family-mono
      font-size: 1rem
      letter-spacing: 0.02em
      color: $color-text

      &:after
        content: "_"
        color: $color-accent-1
        animation: cursor-blink 1.2s step-end infinite

  #logo
    display: inline-block
    float: left
    margin-right: 20px
    width: $logo-width
    height: $logo-height
    border-radius: 5px
    background-size: $logo-width $logo-height
    background-repeat: no-repeat
    if $logo-grayout
      filter: grayscale(100%)
      -webkit-filter: grayscale(100%)

  #nav
    color: $color-accent-1
    letter-spacing: 0.01em
    font-weight: 400
    font-style: normal
    font-size: 0.75rem

    ul
      margin: 0
      padding: 0
      list-style-type: none
      line-height: 1
      display: flex
      align-items: center
      gap: 0

      a
        display: inline-block
        padding: 2px 0
        margin-right: 12px
        color: $color-meta
        background: none
        background-image: none
        transition: color 0.15s ease
        letter-spacing: 0.06em

        &:hover
          color: $color-accent-1
          background: none
          background-image: none

      li
        display: inline-flex
        align-items: center
        margin-right: 0

        &:not(:last-child):after
          content: "·"
          color: $color-meta
          opacity: 0.25
          margin: 0 2px
          font-size: 10px

      li:last-child a
        margin-right: 0

      .icon
        display: none

@keyframes cursor-blink
  0%, 100%
    opacity: 1
  50%
    opacity: 0

if $logo-grayout
  #header:hover
    #logo
      filter: none
      -webkit-filter: none

@media screen and (max-width: 480px)
  #header
    #title
      margin-right: 4rem

    #nav
      ul
        a:hover
          background: none
          background-image: none

        li
          display: none
          border-right: 0

          &:not(:last-child):after
            display: none

        li.icon
          position: absolute
          top: 77px
          right: 1rem
          display: inline-block
          text-align: center

      ul.responsive
        li
          display: block

      a[aria-label="Menu"]
        display: inline-block
        min-width: 48px
        min-height: 48px

    li:not(:first-child)
      padding-top: 1rem
      padding-left: $logo-width + 20px
      font-size: 1rem

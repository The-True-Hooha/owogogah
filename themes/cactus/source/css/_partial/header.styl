// ── HEADER ───────────────────────────────────────────────────────────

#header
  margin: 0 auto 2.5rem
  width: 100%
  display: flex
  align-items: center
  justify-content: space-between
  gap: 1rem

  .header-logo-link
    display: inline-flex
    align-items: center
    background: none
    background-image: none
    text-decoration: none
    flex-shrink: 0

    &:hover
      background: none
      background-image: none

  #logo
    display: block
    width: $logo-width
    height: $logo-height
    border-radius: 4px
    object-fit: contain
    flex-shrink: 0
    if $logo-grayout
      filter: grayscale(100%)
      -webkit-filter: grayscale(100%)

  #nav
    flex: 1
    display: flex
    justify-content: flex-end

    ul
      margin: 0
      padding: 0
      list-style: none
      display: flex
      align-items: center
      gap: 0

    a
      display: inline-block
      padding: 2px 0
      margin-right: 12px
      font-size: 0.75rem
      letter-spacing: 0.06em
      color: $color-meta
      background: none
      background-image: none
      transition: color 0.15s ease

      &:hover
        color: $color-accent-1
        background: none
        background-image: none

    li
      display: inline-flex
      align-items: center

      &:not(:last-child):after
        content: "·"
        color: $color-meta
        opacity: 0.25
        margin: 0 2px
        font-size: 10px

    li:last-child a
      margin-right: 0

  // hamburger — hidden on desktop
  #nav-toggle
    display: none
    flex-direction: column
    justify-content: center
    align-items: center
    gap: 5px
    width: 36px
    height: 36px
    background: none
    border: none
    cursor: pointer
    padding: 4px
    flex-shrink: 0

    span
      display: block
      width: 20px
      height: 1.5px
      background: $color-meta
      border-radius: 1px
      transition: transform 0.25s ease, opacity 0.2s ease

    &[aria-expanded="true"]
      span:nth-child(1)
        transform: translateY(6.5px) rotate(45deg)
      span:nth-child(2)
        opacity: 0
      span:nth-child(3)
        transform: translateY(-6.5px) rotate(-45deg)

if $logo-grayout
  #header:hover
    #logo
      filter: none
      -webkit-filter: none

// ── SIDE DRAWER ──────────────────────────────────────────────────────

#nav-drawer
  position: fixed
  top: 0
  right: 0
  width: 240px
  height: 100%
  background: $color-background
  border-left: 1px solid rgba(43, 188, 138, 0.15)
  z-index: 200
  transform: translateX(100%)
  transition: transform 0.28s cubic-bezier(0.4, 0, 0.2, 1)
  padding: 5rem 2rem 2rem
  display: none  // shown only via media query

  &.drawer-open
    transform: translateX(0)

  nav ul
    list-style: none
    margin: 0
    padding: 0
    display: flex
    flex-direction: column
    gap: 0

  nav li a
    display: block
    padding: 0.75rem 0
    font-size: 0.9rem
    letter-spacing: 0.08em
    color: $color-meta
    background: none
    background-image: none
    border-bottom: 1px solid rgba(144, 141, 141, 0.08)
    transition: color 0.15s ease

    &:hover
      color: $color-accent-1
      background: none
      background-image: none

#nav-overlay
  position: fixed
  inset: 0
  z-index: 199
  background: rgba(0, 0, 0, 0.5)
  opacity: 0
  pointer-events: none
  transition: opacity 0.28s ease
  display: none  // shown only via media query

  &.overlay-open
    opacity: 1
    pointer-events: auto

// ── MOBILE BREAKPOINT ────────────────────────────────────────────────

@media screen and (max-width: 540px)
  #header
    #nav
      display: none  // desktop nav hidden on mobile

    #nav-toggle
      display: flex  // show hamburger

  #nav-drawer
    display: block  // enable drawer

  #nav-overlay
    display: block  // enable overlay

// ── PAGINATION ───────────────────────────────────────────────────────

.pagination
  display: flex
  align-items: center
  justify-content: center
  gap: 0.5rem
  margin-top: 2.5rem
  font-family: $font-family-mono
  font-size: 11px

  .page-number
    color: $color-meta
    opacity: 0.5
    padding: 0 0.5rem

  a
    display: inline-block
    padding: 4px 10px
    color: $color-meta
    background: none
    background-image: none
    border: 1px dotted rgba(144, 141, 141, 0.25)
    border-radius: 2px
    text-decoration: none
    transition: color 0.15s ease, border-color 0.15s ease

    &:hover
      color: $color-accent-1
      border-color: rgba(43, 188, 138, 0.4)
      background: none
      background-image: none

  .extend.prev:before
    content: "← prev"

  .extend.next:before
    content: "next →"

// ================================================================
// owogogah — archive / signal log
// ================================================================

@keyframes archive-fade-up
  from
    opacity: 0
    transform: translateY(8px)
  to
    opacity: 1
    transform: translateY(0)

.archive-wrap
  padding-top: 0.25rem

// ── HEADER ───────────────────────────────────────────────────────

.archive-header
  margin-bottom: 2.5rem
  padding-bottom: 1.5rem
  border-bottom: 1px solid rgba(43, 188, 138, 0.15)
  opacity: 0
  animation: archive-fade-up 0.4s ease 0.05s forwards

.archive-eyebrow
  font-size: 10px
  letter-spacing: 0.2em
  text-transform: uppercase
  color: $color-accent-1
  opacity: 0.7
  margin-bottom: 0.5rem

.archive-meta-row
  display: flex
  align-items: center
  gap: 0.6rem
  font-size: 12px
  color: $color-meta

.archive-count
  color: $color-text
  font-weight: 700

.archive-sep
  opacity: 0.4

.archive-since
  opacity: 0.6

// ── YEAR BLOCKS ──────────────────────────────────────────────────

.archive-year-block
  margin-bottom: 2.5rem
  opacity: 0
  animation: archive-fade-up 0.4s ease forwards

  &:nth-child(2) { animation-delay: 0.1s }
  &:nth-child(3) { animation-delay: 0.17s }
  &:nth-child(4) { animation-delay: 0.24s }
  &:nth-child(5) { animation-delay: 0.31s }
  &:nth-child(6) { animation-delay: 0.38s }

.archive-year-header
  display: flex
  align-items: center
  gap: 0.5rem
  margin-bottom: 0.75rem
  padding-bottom: 0.5rem
  border-bottom: 1px dotted $color-border

.archive-bracket
  color: $color-accent-1
  font-weight: 700
  font-size: 13px

.archive-year-num
  font-size: 13px
  font-weight: 700
  color: $color-text
  letter-spacing: 0.02em

.archive-year-count
  font-size: 9px
  letter-spacing: 0.12em
  text-transform: uppercase
  color: $color-meta
  opacity: 0.5
  margin-left: 0.25rem

// ── POST LIST ────────────────────────────────────────────────────

.archive-post-list
  padding: 0
  margin: 0
  list-style: none

.archive-post-item
  display: grid
  grid-template-columns: 46px 1fr
  grid-template-rows: auto auto
  gap: 0.15rem 0.85rem
  padding: 0.55rem 0.5rem
  border-bottom: 1px dotted rgba(144, 141, 141, 0.2)
  transition: background 0.15s ease
  border-radius: 2px

  &:first-child
    border-top: 1px dotted rgba(144, 141, 141, 0.2)

  &:hover
    background: none

    .archive-post-title a
      color: #ffffff

  @media (min-width: 520px)
    grid-template-columns: 46px 1fr auto auto
    grid-template-rows: auto
    align-items: center

.archive-post-date
  font-size: 10px
  color: $color-meta
  opacity: 0.5
  letter-spacing: 0.04em
  align-self: center
  grid-column: 1
  grid-row: 1
  white-space: nowrap

  @media (min-width: 520px)
    grid-row: 1

.archive-post-title
  font-size: 13px
  grid-column: 2
  grid-row: 1
  align-self: center

  a
    color: $color-text
    background: none
    text-decoration: none
    transition: color 0.2s ease

    &:hover
      color: #ffffff
      background: none
      background-image: none

.archive-post-tags
  display: flex
  flex-wrap: wrap
  gap: 0.3rem
  grid-column: 2
  grid-row: 2
  padding-top: 0.15rem

  @media (min-width: 520px)
    grid-column: 3
    grid-row: 1
    justify-content: flex-end
    padding-top: 0

.archive-tag
  font-size: 9px
  letter-spacing: 0.08em
  color: $color-meta
  opacity: 0.55
  background: none
  text-decoration: none
  padding: 1px 5px
  border: 1px dotted rgba(144, 141, 141, 0.3)
  border-radius: 2px
  white-space: nowrap
  transition: color 0.15s ease, border-color 0.15s ease, opacity 0.15s ease

  &:hover
    color: $color-accent-1
    border-color: rgba(43, 188, 138, 0.4)
    opacity: 1
    background: none
    background-image: none

.archive-post-time
  font-size: 9px
  letter-spacing: 0.08em
  color: $color-meta
  opacity: 0.35
  white-space: nowrap
  grid-column: 1 / span 2
  grid-row: 3
  padding-left: calc(46px + 0.85rem)

  @media (min-width: 520px)
    grid-column: 4
    grid-row: 1
    padding-left: 0
    margin-left: 0.75rem

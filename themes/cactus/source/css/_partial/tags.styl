// ── TAG CLOUD PAGE ───────────────────────────────────────────────────

#tag-cloud
  padding: 1rem 0 2rem

  .tag-cloud-title
    font-size: 10px
    letter-spacing: 0.2em
    text-transform: uppercase
    color: $color-accent-1
    opacity: 0.7
    margin-bottom: 2rem
    font-family: $font-family-mono

  .tag-cloud-tags
    clear: both
    text-align: left
    line-height: 2.2

    a
      display: inline-block
      margin: 0 0.4rem 0.4rem 0
      padding: 3px 8px
      font-size: 11px !important  // override tagcloud() inline sizes
      font-family: $font-family-mono
      color: $color-meta
      background: none
      background-image: none
      border: 1px dotted rgba(144, 141, 141, 0.25)
      border-radius: 2px
      letter-spacing: 0.06em
      transition: color 0.15s ease, border-color 0.15s ease

      &:before
        content: "#"
        opacity: 0.4
        margin-right: 1px

      &:hover
        color: $color-accent-1
        border-color: rgba(43, 188, 138, 0.4)
        background: none
        background-image: none

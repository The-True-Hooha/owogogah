// ── /now PAGE ────────────────────────────────────────────────────────

.now-wrap
  padding: 2rem 0 3rem
  max-width: 42rem
  animation: post-fade-in 0.4s ease both

.now-eyebrow
  font-size: 10px
  letter-spacing: 0.2em
  text-transform: uppercase
  color: $color-accent-1
  opacity: 0.7
  margin-bottom: 0.75rem
  font-family: $font-family-mono

.now-title
  font-size: 1.5rem
  font-weight: 700
  letter-spacing: -0.02em
  color: $color-text
  margin: 0 0 0.5rem 0

.now-meta
  font-size: 11px
  color: $color-meta
  opacity: 0.5
  font-family: $font-family-mono
  margin-bottom: 2.5rem

  .now-date
    color: $color-accent-1
    opacity: 1

.now-content
  font-size: 14px
  line-height: 1.85
  color: $color-text

  h2
    font-size: 0.85rem
    font-weight: 700
    letter-spacing: 0.1em
    text-transform: uppercase
    color: $color-meta
    margin-top: 2rem
    margin-bottom: 0.6rem
    opacity: 0.7

  p
    margin-bottom: 1.2rem

  a
    color: $color-accent-1
    background: none
    background-image: none
    border-bottom: 1px dotted rgba(43, 188, 138, 0.4)
    transition: border-color 0.15s ease

    &:hover
      background: none
      background-image: none
      border-color: $color-accent-1

  hr
    border: none
    border-top: 1px dotted rgba(144, 141, 141, 0.2)
    margin: 2rem 0

  strong
    color: $color-text
    font-weight: 700

  em
    color: $color-meta
    font-style: italic

  code
    font-size: 11px
    font-family: $font-family-mono
    color: $color-accent-1
    background: rgba(43, 188, 138, 0.07)
    border: 1px dotted rgba(43, 188, 138, 0.2)
    border-radius: 2px
    padding: 1px 5px

.now-footer
  margin-top: 3rem
  padding-top: 1.5rem
  border-top: 1px solid rgba(43, 188, 138, 0.1)

  .now-note
    font-size: 11px
    color: $color-meta
    opacity: 0.4
    font-family: $font-family-mono

    a
      color: $color-meta
      background: none
      background-image: none
      border-bottom: 1px dotted rgba(144, 141, 141, 0.3)
      transition: color 0.15s ease

      &:hover
        color: $color-accent-1
        background: none
        background-image: none
